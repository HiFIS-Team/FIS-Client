# PostgreSQL 연결 문자열
# docker compose 사용 시 host를 서비스명(db)으로: postgresql://fis:fis@db:5432/fis?schema=public
DATABASE_URL="postgresql://fis:fis@localhost:5432/fis?schema=public"

# 지원서 첨부파일 저장 경로 (docker 볼륨으로 마운트 권장)
UPLOAD_DIR="./uploads"

# Auth.js (관리자 로그인)
# AUTH_SECRET: openssl rand -base64 32 로 생성
AUTH_SECRET=""
# 구글 OAuth 클라이언트 (Google Cloud Console > 사용자 인증 정보)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# 관리자 허용 구글 계정 이메일 (쉼표 구분)
ADMIN_EMAILS="admin1@gmail.com,admin2@gmail.com"

# ───────── 운영(docker compose) 전용 ─────────
# 서버의 .env에 두면 docker-compose가 DATABASE_URL을 조립합니다.
FIS_DB_USER="fis"
FIS_DB_PASSWORD="강한_비밀번호로_변경"
FIS_DB_NAME="fis_db"
# 운영 공개 URL (Auth.js 콜백용)
AUTH_URL="https://fitnessstar.co.kr"

# ───────── 알림톡 (Solapi) — 지점별 ─────────
# 채널/템플릿 검수 완료 후 채우면 자동 발송됩니다. 비우면 발송 스킵.
# ⚠️ 값 뒤에 인라인 주석(# ...)을 붙이지 마세요. docker compose가 주석까지 값으로
#    읽어 발신번호 등이 깨질 수 있습니다. 설명은 항상 값 위 별도 줄에 둡니다.

# 공통 (계정)
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
# 발신번호 (숫자만, 예: 0212345678)
SOLAPI_SENDER=""
# 새 지원 알림 받을 직원 수신번호 (쉼표): 대표,나
ALERT_PHONES=""

# 지점별 (번호 N = src/data/site.ts 의 branches 순서와 일치)
#   현재: _1=화순점, _2=첨단점, _3=동광주점
#   각 지점: PFID=카카오 발신프로필(KA01PF...), TEMPLATE_*=검수된 템플릿 ID
#   NEW=새지원(직원), RECEIVED=지원완료, DOCPASS=서류합격, FINALPASS=최종합격, FAIL=불합격
# 지점1 (화순점)
SOLAPI_PFID_1=""
SOLAPI_TEMPLATE_NEW_1=""
SOLAPI_TEMPLATE_RECEIVED_1=""
SOLAPI_TEMPLATE_DOCPASS_1=""
SOLAPI_TEMPLATE_FINALPASS_1=""
SOLAPI_TEMPLATE_FAIL_1=""
# 지점2 (첨단점)
SOLAPI_PFID_2=""
SOLAPI_TEMPLATE_NEW_2=""
SOLAPI_TEMPLATE_RECEIVED_2=""
SOLAPI_TEMPLATE_DOCPASS_2=""
SOLAPI_TEMPLATE_FINALPASS_2=""
SOLAPI_TEMPLATE_FAIL_2=""
# 지점3 (동광주점)
SOLAPI_PFID_3=""
SOLAPI_TEMPLATE_NEW_3=""
SOLAPI_TEMPLATE_RECEIVED_3=""
SOLAPI_TEMPLATE_DOCPASS_3=""
SOLAPI_TEMPLATE_FINALPASS_3=""
SOLAPI_TEMPLATE_FAIL_3=""
