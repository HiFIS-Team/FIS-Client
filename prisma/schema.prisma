generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 채용 공고
model Opening {
  id               String   @id @default(cuid())
  title            String
  group            String // office | field | coach
  job              String
  location         String
  employment       String // 정규직 | 계약직 | 인턴 | 파트타임
  career           String // 신입 | 경력 | 경력무관
  /// 급여 (여러 줄, 비우면 미표시)
  salary           String[]
  /// 근무 시간 (여러 줄, 비우면 미표시)
  workHours        String[]
  summary          String
  /// 지도에 표시할 실제 주소 (필수)
  address          String
  hot              Boolean  @default(false)
  applyUrl         String?
  description      String?
  appeal           String[]
  responsibilities String[]
  qualifications   String[]
  preferred        String[]
  /// 공개 여부 (초안/게시)
  published        Boolean  @default(true)
  /// 정렬 순서 (작을수록 위)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([published, sortOrder])
}

/// 지원서 접수 기록
model Application {
  id           String   @id @default(cuid())
  openingId    String
  openingTitle String
  /// 지점명(화순점/첨단점/동광주점) — 지점별 알림톡 발송에 사용. 미매칭이면 null
  branch       String?
  name         String
  email        String
  phone        String
  agreedTerms  String[]
  /// 첨부 파일 메타 [{ label, name, path, size }]
  files        Json
  /// 전형 상태: 접수 | 서류합격 | 최종합격 | 불합격
  status       String   @default("접수")
  createdAt    DateTime @default(now())

  @@index([openingId])
  @@index([status])
  @@index([createdAt])
}
